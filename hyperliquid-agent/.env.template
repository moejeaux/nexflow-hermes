# ═══════════════════════════════════════════════════════════════════════════
# NXFH01 — Degen Claw Hyperliquid Trading Agent
# ═══════════════════════════════════════════════════════════════════════════

# === G.A.M.E. SDK (required) ===
GAME_API_KEY=                        # From console.game.virtuals.io
GAME_AGENT_ID=                       # Existing agent ID (skip creation if set)

# === ACP CLI (required for LIVE trading) ===
# Path to openclaw-acp installation directory
ACP_CLI_DIR=~/nexflow-virtuals/openclaw-acp

# === ACP Credentials ===
ACP_WALLET_PRIVATE_KEY=              # Dev wallet private key (no 0x prefix)
ACP_WALLET_ADDRESS=                  # Butler Wallet address (0x...) — your identity on the platform.
                                     # This is NOT the HL subaccount. Degen Claw maps the Butler
                                     # wallet to your HL trading subaccount automatically.
ACP_ENTITY_ID=                       # Agent entity ID from Virtuals

# === Hyperliquid (read-only data) ===
HL_WALLET_ADDRESS=                   # Same as ACP_WALLET_ADDRESS (Butler Wallet).
                                     # The HL subaccount is managed by Degen Claw and
                                     # linked to your Butler wallet via ACP.
HL_API_URL=https://api.hyperliquid.xyz
HL_KILL_SWITCH=false                 # Set to 'true' to halt all trading

# === Degen Claw equity override ===
# If Degen Claw manages a subaccount, HL user_state returns $0.
# Set this to the actual deposited equity so the agent knows its balance.
INITIAL_EQUITY=50.0

# === Notifications (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
