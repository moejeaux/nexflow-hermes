# =============================================================================
# Hermes Agent Environment Variables — NexFlow Deployment
# =============================================================================
# Copy this file to ~/.hermes/.env and fill in real values.
# NEVER commit the .env file with real keys to version control.
# =============================================================================

# --- LLM Provider (OpenRouter) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Web Search & Extraction (Firecrawl) ---
# Get your key at https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram, paste the token here
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (numeric). Only this user can interact with the bot.
# Find your ID by messaging @userinfobot on Telegram.
TELEGRAM_ALLOWED_USERS=

# --- Base Chain RPC (Alchemy) ---
# Get your key at https://www.alchemy.com/ — select Base mainnet
ALCHEMY_API_KEY=

# --- On-Chain Analytics (Bitquery) ---
# Get your key at https://bitquery.io/
BITQUERY_API_KEY=

# --- Blockscout (Base chain) ---
# No API key required — free public API
# Override URL only if using a custom/self-hosted Blockscout instance
# BLOCKSCOUT_BASE_URL=https://base.blockscout.com

# --- NexFlow API ---
# API key for authenticating with NexFlow Pulse/SMF endpoints
NEXFLOW_API_KEY=
# Base URL for NexFlow API (default: production endpoint)
NEXFLOW_BASE_URL=https://api.nexflowapp.app

# --- NXFX01 Launch Intelligence ---
# Supabase connection string for the NXFX01 database
NXFX01_DATABASE_URL=
# API key for nxfx01-api (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
NXFX01_API_KEY=
# URL for the nxfx01-api service (default: localhost)
NXFX01_API_URL=http://localhost:8100

# =============================================================================
# SECURITY NOTES:
# - NEVER set GATEWAY_ALLOW_ALL_USERS=true
# - Keep TELEGRAM_ALLOWED_USERS restricted to your personal ID only
# - Rotate keys periodically
# - This file should be chmod 600 (owner read/write only)
# =============================================================================
